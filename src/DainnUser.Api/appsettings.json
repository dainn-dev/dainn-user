{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "DainnUser": {
    "Database": {
      "Provider": "SQLite",
      "ConnectionString": "Data Source=dainnuser.db"
    },
    "Email": {
      "SmtpHost": "smtp.gmail.com",
      "SmtpPort": 587,
      "SmtpUsername": "your-email@gmail.com",
      "SmtpPassword": "your-app-password",
      "FromEmail": "noreply@yourdomain.com",
      "FromName": "DainnUser",
      "EnableSsl": true
    },
    "Jwt": {
      "Secret": "REPLACE-WITH-A-SECURE-RANDOM-SECRET-AT-LEAST-32-CHARS",
      "Issuer": "DainnUser",
      "Audience": "DainnUser"
    },
    "RateLimiting": {
      "Enabled": true,
      "Rules": [
        { "Endpoint": "/api/auth/login", "MaxRequests": 5, "WindowSeconds": 60, "Mode": "PerIp" },
        { "Endpoint": "/api/auth/register", "MaxRequests": 3, "WindowSeconds": 300, "Mode": "PerIp" },
        { "Endpoint": "/api/auth/resend-verification", "MaxRequests": 3, "WindowSeconds": 300, "Mode": "PerIp" },
        { "Endpoint": "/api/auth/forgot-password", "MaxRequests": 3, "WindowSeconds": 300, "Mode": "PerIp" },
        { "Endpoint": "/api/auth/reset-password", "MaxRequests": 5, "WindowSeconds": 300, "Mode": "PerIp" },
        { "Endpoint": "/api/auth/refresh-token", "MaxRequests": 30, "WindowSeconds": 60, "Mode": "PerIp" },
        { "Endpoint": "/api/auth/logout", "MaxRequests": 30, "WindowSeconds": 60, "Mode": "PerUser" },
        { "Endpoint": "/api/auth/admin/*", "MaxRequests": 10, "WindowSeconds": 60, "Mode": "PerUser" },
        { "Endpoint": "/api/auth/*", "MaxRequests": 30, "WindowSeconds": 60, "Mode": "PerIp" }
      ],
      "WhitelistIps": []
    }
  }
}
