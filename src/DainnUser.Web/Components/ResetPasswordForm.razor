@namespace DainnUser.Web.Components

<EditForm Model="Model" OnValidSubmit="HandleSubmitAsync" class="@CssClass">
    <DataAnnotationsValidator />
    <ValidationSummary class="text-danger mb-3" />

    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <div class="alert alert-danger" role="alert">@ErrorMessage</div>
    }

    <div class="mb-3">
        <label class="form-label" for="@_tokenId">Reset token</label>
        <InputText id="@_tokenId" class="form-control" autocomplete="one-time-code" @bind-Value="Model.Token" />
        <ValidationMessage For="@(() => Model.Token)" class="text-danger" />
    </div>

    <div class="mb-3">
        <label class="form-label" for="@_passwordId">New password</label>
        <InputText id="@_passwordId" class="form-control" type="password" autocomplete="new-password" @bind-Value="Model.NewPassword" />
        <ValidationMessage For="@(() => Model.NewPassword)" class="text-danger" />
    </div>

    <div class="mb-3">
        <label class="form-label" for="@_confirmPasswordId">Confirm password</label>
        <InputText id="@_confirmPasswordId" class="form-control" type="password" autocomplete="new-password" @bind-Value="Model.ConfirmPassword" />
        <ValidationMessage For="@(() => Model.ConfirmPassword)" class="text-danger" />
    </div>

    <button type="submit" class="btn btn-primary w-100" disabled="@IsSubmitting">
        @(IsSubmitting ? LoadingText : SubmitText)
    </button>
</EditForm>

@code {
    private readonly string _tokenId = $"du-reset-token-{Guid.NewGuid():N}";
    private readonly string _passwordId = $"du-reset-password-{Guid.NewGuid():N}";
    private readonly string _confirmPasswordId = $"du-reset-confirm-{Guid.NewGuid():N}";

    [Parameter] public ResetPasswordFormModel Model { get; set; } = new();
    [Parameter] public EventCallback<ResetPasswordFormModel> OnSubmit { get; set; }
    [Parameter] public bool IsSubmitting { get; set; }
    [Parameter] public string SubmitText { get; set; } = "Reset password";
    [Parameter] public string LoadingText { get; set; } = "Resetting...";
    [Parameter] public string? ErrorMessage { get; set; }
    [Parameter] public string? CssClass { get; set; }

    private async Task HandleSubmitAsync()
    {
        await OnSubmit.InvokeAsync(Model);
    }
}
