@namespace DainnUser.Web.Components

<EditForm Model="Model" OnValidSubmit="HandleSubmitAsync" class="@CssClass">
    <DataAnnotationsValidator />
    <ValidationSummary class="text-danger mb-3" />

    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <div class="alert alert-danger" role="alert">@ErrorMessage</div>
    }

    <div class="mb-3">
        <label class="form-label" for="@_codeId">Authentication code</label>
        <InputText id="@_codeId" class="form-control" inputmode="numeric" autocomplete="one-time-code" maxlength="6" @bind-Value="Model.Code" />
        <ValidationMessage For="@(() => Model.Code)" class="text-danger" />
    </div>

    @if (EnableRememberDevice)
    {
        <div class="mb-3 form-check">
            <InputCheckbox id="@_rememberId" class="form-check-input" @bind-Value="Model.RememberDevice" />
            <label class="form-check-label" for="@_rememberId">Trust this device</label>
        </div>
    }

    <button type="submit" class="btn btn-primary w-100" disabled="@IsSubmitting">
        @(IsSubmitting ? LoadingText : SubmitText)
    </button>
</EditForm>

@code {
    private readonly string _codeId = $"du-2fa-code-{Guid.NewGuid():N}";
    private readonly string _rememberId = $"du-2fa-remember-{Guid.NewGuid():N}";

    [Parameter] public TwoFactorCodeFormModel Model { get; set; } = new();
    [Parameter] public EventCallback<TwoFactorCodeFormModel> OnSubmit { get; set; }
    [Parameter] public bool EnableRememberDevice { get; set; } = true;
    [Parameter] public bool IsSubmitting { get; set; }
    [Parameter] public string SubmitText { get; set; } = "Verify";
    [Parameter] public string LoadingText { get; set; } = "Verifying...";
    [Parameter] public string? ErrorMessage { get; set; }
    [Parameter] public string? CssClass { get; set; }

    private async Task HandleSubmitAsync()
    {
        await OnSubmit.InvokeAsync(Model);
    }
}
