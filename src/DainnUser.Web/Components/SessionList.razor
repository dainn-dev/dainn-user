@namespace DainnUser.Web.Components

@if (!string.IsNullOrWhiteSpace(ErrorMessage))
{
    <div class="alert alert-danger" role="alert">@ErrorMessage</div>
}

@if (!string.IsNullOrWhiteSpace(SuccessMessage))
{
    <div class="alert alert-success" role="status">@SuccessMessage</div>
}

@if (Sessions.Count == 0)
{
    <p class="text-muted">No active sessions found.</p>
}
else
{
    <ul class="list-group @CssClass" aria-label="Active sessions">
        @foreach (var session in Sessions)
        {
            <li class="list-group-item d-flex justify-content-between align-items-start gap-2">
                <div class="flex-grow-1 overflow-hidden">
                    <div class="d-flex align-items-center gap-2 flex-wrap">
                        <span class="fw-semibold text-truncate">@FormatUserAgent(session.UserAgent)</span>
                        @if (session.IsCurrent)
                        {
                            <span class="badge text-bg-success">Current session</span>
                        }
                    </div>
                    <small class="text-muted d-block">
                        @(string.IsNullOrWhiteSpace(session.IpAddress) ? "Unknown IP" : session.IpAddress)
                        &nbsp;·&nbsp;Active @FormatRelativeTime(session.LastActivityAt)
                    </small>
                    <small class="text-muted d-block">
                        Started @session.CreatedAt.ToLocalTime().ToString("MMM d, yyyy HH:mm")
                        &nbsp;·&nbsp;Expires @session.ExpiresAt.ToLocalTime().ToString("MMM d, yyyy")
                    </small>
                </div>
                @if (!session.IsCurrent)
                {
                    <button type="button"
                            class="btn btn-sm btn-outline-danger flex-shrink-0"
                            @onclick="() => HandleRevokeAsync(session.Id)"
                            disabled="@IsSubmitting"
                            aria-label="Revoke this session">
                        Revoke
                    </button>
                }
            </li>
        }
    </ul>

    @if (Sessions.Any(s => !s.IsCurrent))
    {
        <div class="mt-3">
            <button type="button"
                    class="btn btn-outline-danger btn-sm"
                    @onclick="HandleRevokeAllOtherAsync"
                    disabled="@IsSubmitting">
                @(IsSubmitting ? "Signing out..." : "Sign out all other devices")
            </button>
        </div>
    }
}

@code {
    [Parameter] public IReadOnlyList<SessionViewModel> Sessions { get; set; } = Array.Empty<SessionViewModel>();
    [Parameter] public EventCallback<Guid> OnRevokeSession { get; set; }
    [Parameter] public EventCallback OnRevokeAllOther { get; set; }
    [Parameter] public bool IsSubmitting { get; set; }
    [Parameter] public string? ErrorMessage { get; set; }
    [Parameter] public string? SuccessMessage { get; set; }
    [Parameter] public string? CssClass { get; set; }

    private async Task HandleRevokeAsync(Guid sessionId)
    {
        await OnRevokeSession.InvokeAsync(sessionId);
    }

    private async Task HandleRevokeAllOtherAsync()
    {
        await OnRevokeAllOther.InvokeAsync();
    }

    private static string FormatUserAgent(string? userAgent)
    {
        if (string.IsNullOrWhiteSpace(userAgent)) return "Unknown device";
        if (userAgent.Contains("Edg", StringComparison.OrdinalIgnoreCase)) return "Microsoft Edge";
        if (userAgent.Contains("Chrome", StringComparison.OrdinalIgnoreCase)) return "Google Chrome";
        if (userAgent.Contains("Firefox", StringComparison.OrdinalIgnoreCase)) return "Mozilla Firefox";
        if (userAgent.Contains("Safari", StringComparison.OrdinalIgnoreCase)) return "Safari";
        return userAgent.Length > 60 ? string.Concat(userAgent.AsSpan(0, 60), "…") : userAgent;
    }

    private static string FormatRelativeTime(DateTime utcTime)
    {
        var diff = DateTime.UtcNow - utcTime;
        if (diff.TotalMinutes < 1) return "just now";
        if (diff.TotalHours < 1) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalDays < 1) return $"{(int)diff.TotalHours}h ago";
        return $"{(int)diff.TotalDays}d ago";
    }
}
